#!/usr/bin/env bash
# Pre-push: run the same gates CI enforces, so a formatting or clippy slip is
# caught before it costs a CI round-trip.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass in a pinch with:  git push --no-verify
exec "$(git rev-parse --show-toplevel)/scripts/check.sh"
